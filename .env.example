# ---- Kafka ----
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=customer-signals
KAFKA_DLQ_TOPIC=customer-signals-dlq
KAFKA_CONSUMER_GROUP=triage-service

# ---- Producer ----
EVENTS_PER_SECOND=2
BRANDS=acme,globex,initech

# ---- LLM (triage-service) ----
# Leave blank to fall back to the built-in heuristic classifier (no external calls).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---- Cassandra ----
CASSANDRA_HOSTS=cassandra
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=customer_signals

# ---- Elasticsearch ----
ES_URL=http://elasticsearch:9200
ES_INDEX=customer-signals

# ---- Redis ----
REDIS_URL=redis://redis:6379/0
STATS_TTL_SECONDS=86400

# ---- Triage service ----
TRIAGE_HEALTH_PORT=8000

# ---- Query API ----
QUERY_API_PORT=8080
JWT_SECRET=change-me-in-production
JWT_ISSUER=customer-signal-pipeline
RATE_LIMIT_PER_MINUTE=60
CB_FAILURE_THRESHOLD=5
CB_COOLDOWN_SECONDS=30
